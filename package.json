{
  "name": "atlas",
  "version": "0.0.0",
  "private": true,
  "workspaces": ["apps/*", "packages/*", "packages/infrastructure/*"],
  "scripts": {
    "dev": "bun nx run-many -t dev --parallel=4",
    "typecheck": "bun nx run-many -t typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "build": "bun nx run-many -t build"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@tailwindcss/postcss": "^4.3.1",
    "bun-types": "^1.3.13",
    "nx": "^20.3.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.7.3"
  }
}

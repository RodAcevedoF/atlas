{
  "compilerOptions": {
    "strict": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "paths": {
      "@atlas/domain": ["./packages/domain/src/index.ts"],
      "@atlas/application": ["./packages/application/src/index.ts"],
      "@atlas/orchestration": ["./packages/orchestration/src/index.ts"],
      "@atlas/shared": ["./packages/shared/src/index.ts"],
      "@atlas/ui": ["./packages/ui/src/index.ts"],
      "@atlas/infra/*": ["./packages/infrastructure/src/*/index.ts"]
    }
  }
}
